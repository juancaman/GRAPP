# Variables de Entorno para Rodríguez Conecta

# ===== DATABASE (NEON) =====
# Obtener en: https://console.neon.tech → Connection String
# Formato: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://your_user:your_password@ep-xyz.us-east-1.neon.tech/neondb?sslmode=require

# ===== CLERK AUTH =====
# Obtener en: https://dashboard.clerk.com → API Keys
# PUBLISHABLE: usar en frontend (visible)
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx

# SECRET: usar SOLO en backend (secreto)
CLERK_SECRET_KEY=sk_live_yyyyyyyyyyyyyyyyyyyyyyy

# ===== IMGBB IMAGE API =====
# Obtener en: https://imgbb.com/account/settings/api
VITE_IMGBB_KEY=zzzzzzzzzzzzzzzzzzzzzzzzzz

# ===== ADMIN EMAIL =====
# Tu email para acceder a panel admin
VITE_ADMIN_EMAIL=tu.email@dominio.com

# ===== NOTAS =====
# 1. Copiar este archivo a .env.local
# 2. Llenar con tus valores reales
# 3. NUNCA commitear .env.local a git
# 4. CLERK_SECRET_KEY debe estar SOLO en backend
