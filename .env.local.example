# Copiar este archivo a .env.local y rellenar con tus valores

# ===== DATABASE (Neon) =====
# De https://console.neon.tech/app/projects
DATABASE_URL=postgresql://user:password@ep-xxxxx-xxxxx.neon.tech/neon

# ===== CLERK =====
# De https://dashboard.clerk.com/apps/[app-id]/api-keys
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== IMGBB =====
# De https://imgbb.com/settings/api
VITE_IMGBB_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== ADMIN =====
# Tu email (el que usarás para loguearTE en Clerk)
VITE_ADMIN_EMAIL=tuemailadmin@gmail.com

# ===== OPCIONAL - PARA DEPLOY =====
# Frontend API URL (si es diferente del localhost)
# VITE_API_URL=https://tu-dominio.com/api/db
